@page "/nl-query"
@inject HttpClient Http

<PageTitle>NL → SQL Query</PageTitle>

<h2>🧠 Module 1 – Natural Language → SQL</h2>
<p class="text-muted">
    Ask a question in plain English or Serbian. The AI generates SQL, executes it, and shows the results.
</p>

<div class="card mb-4">
    <div class="card-body">
        <label class="form-label fw-bold">Your Question</label>
        <div class="input-group">
            <input class="form-control form-control-lg"
                   @bind="question"
                   placeholder="e.g. Which carrier has the most delays in the last 30 days?"
                   @onkeydown="HandleKeyDown" />
            <button class="btn btn-primary" @onclick="SubmitQuery" disabled="@isLoading">
                @if (isLoading)
                {
                    <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                    <span>Generating...</span>
                }
                else
                {
                    <span>Ask AI</span>
                }
            </button>
        </div>

        <div class="mt-3">
            <small class="text-muted">Example questions:</small><br />
            @foreach (var example in exampleQuestions)
            {
                <button class="btn btn-outline-secondary btn-sm me-1 mt-1"
                        @onclick="() => SetQuestion(example)">
                    @example
                </button>
            }
        </div>
    </div>
</div>

@if (errorMessage != null)
{
    <div class="alert alert-danger">
        <strong>Error:</strong> @errorMessage
        @if (generatedSql != null)
        {
            <pre class="mt-2 mb-0 small">@generatedSql</pre>
        }
    </div>
}

@if (result != null)
{
    <div class="card mb-3">
        <div class="card-header bg-light">
            <strong>Generated SQL</strong>
            <span class="badge bg-secondary ms-2">@result.RowCount row(s)</span>
        </div>
        <div class="card-body">
            <pre class="mb-0 p-2 bg-dark text-light rounded"><code>@result.Sql</code></pre>
        </div>
    </div>

    @if (result.Result != null && result.Result.Count > 0)
    {
        <div class="card">
            <div class="card-header bg-light"><strong>Results</strong></div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-striped table-hover mb-0">
                        <thead class="table-dark">
                            <tr>
                                @foreach (var col in result.Result[0].Keys)
                                {
                                    <th>@col</th>
                                }
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var row in result.Result)
                            {
                                <tr>
                                    @foreach (var val in row.Values)
                                    {
                                        <td>@(val?.ToString() ?? "–")</td>
                                    }
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="alert alert-warning">No results returned.</div>
    }
}

@code {
    private string question = string.Empty;
    private bool isLoading = false;
    private string? errorMessage;
    private string? generatedSql;
    private QueryResponse? result;

    private readonly string[] exampleQuestions =
    [
        "Which carrier has the most delays in the last 30 days?",
        "What is the average transport cost per ton for the Beograd–Niš route?",
        "Show top 5 routes by total cargo weight this year",
        "How many transports were delayed due to rain?",
        "List all transports with delay from Beograd in the last 7 days"
    ];

    private void SetQuestion(string q)
    {
        question = q;
        result = null;
        errorMessage = null;
    }

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await SubmitQuery();
    }

    private async Task SubmitQuery()
    {
        if (string.IsNullOrWhiteSpace(question)) return;

        isLoading = true;
        errorMessage = null;
        result = null;
        generatedSql = null;

        try
        {
            var response = await Http.PostAsJsonAsync("api/ai/query", new { Question = question });
            if (response.IsSuccessStatusCode)
            {
                result = await response.Content.ReadFromJsonAsync<QueryResponse>();
            }
            else
            {
                var error = await response.Content.ReadFromJsonAsync<ErrorResponse>();
                errorMessage = error?.Error ?? "Unknown error.";
                generatedSql = error?.GeneratedSql;
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to connect to API: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private class QueryResponse
    {
        public string Sql { get; set; } = string.Empty;
        public int RowCount { get; set; }
        public List<Dictionary<string, object?>> Result { get; set; } = [];
    }

    private class ErrorResponse
    {
        public string? Error { get; set; }
        public string? GeneratedSql { get; set; }
    }
}
