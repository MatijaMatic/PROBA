@page "/route-optimizer"
@inject HttpClient Http

<PageTitle>Route Optimizer</PageTitle>

<h2>🗺️ Module 3 – Route Optimizer</h2>
<p class="text-muted">
    Find the cheapest and fastest transport routes using Dijkstra's algorithm.
</p>

<div class="card mb-4">
    <div class="card-body">
        <div class="row g-3">
            <div class="col-md-4">
                <label class="form-label">From City</label>
                <input class="form-control" @bind="request.From" placeholder="e.g. Beograd" list="cities-list" />
            </div>
            <div class="col-md-4">
                <label class="form-label">To City</label>
                <input class="form-control" @bind="request.To" placeholder="e.g. Niš" list="cities-list" />
            </div>
            <div class="col-md-4">
                <label class="form-label">Weight (tons)</label>
                <input type="number" class="form-control" @bind="request.WeightTons"
                       min="0.1" step="0.1" placeholder="e.g. 10" />
            </div>
            <div class="col-md-4">
                <label class="form-label">Cargo Type</label>
                <select class="form-select" @bind="request.CargoType">
                    @foreach (var ct in cargoTypes)
                    {
                        <option value="@ct">@ct</option>
                    }
                </select>
            </div>
            <div class="col-md-4">
                <label class="form-label">Wagon Type</label>
                <select class="form-select" @bind="request.WagonType">
                    @foreach (var wt in wagonTypes)
                    {
                        <option value="@wt">@wt</option>
                    }
                </select>
            </div>
        </div>

        @if (availableCities.Count > 0)
        {
            <datalist id="cities-list">
                @foreach (var city in availableCities)
                {
                    <option value="@city" />
                }
            </datalist>
        }

        <div class="mt-3">
            <button class="btn btn-success" @onclick="OptimizeRoute" disabled="@isLoading">
                @if (isLoading)
                {
                    <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                    <span>Optimizing...</span>
                }
                else
                {
                    <span>🗺️ Find Routes</span>
                }
            </button>
        </div>
    </div>
</div>

@if (errorMessage != null)
{
    <div class="alert alert-danger"><strong>Error:</strong> @errorMessage</div>
}

@if (routeResult != null)
{
    <div class="row">
        @if (routeResult.CheapestRoute != null)
        {
            <div class="col-md-6 mb-3">
                <div class="card border-success">
                    <div class="card-header bg-success text-white">
                        💰 Cheapest Route
                    </div>
                    <div class="card-body">
                        <p>
                            <strong>Path:</strong>
                            @string.Join(" → ", routeResult.CheapestRoute.Path)
                        </p>
                        <p><strong>Total Cost:</strong> €@routeResult.CheapestRoute.TotalCost.ToString("F2")</p>
                        <p><strong>Est. Time:</strong> @routeResult.CheapestRoute.TotalTimeHours.ToString("F1") hours</p>
                        <p><strong>Stops:</strong> @(routeResult.CheapestRoute.Path.Count - 1)</p>
                    </div>
                </div>
            </div>
        }

        @if (routeResult.FastestRoute != null)
        {
            <div class="col-md-6 mb-3">
                <div class="card border-primary">
                    <div class="card-header bg-primary text-white">
                        ⚡ Fastest Route
                    </div>
                    <div class="card-body">
                        <p>
                            <strong>Path:</strong>
                            @string.Join(" → ", routeResult.FastestRoute.Path)
                        </p>
                        <p><strong>Total Cost:</strong> €@routeResult.FastestRoute.TotalCost.ToString("F2")</p>
                        <p><strong>Est. Time:</strong> @routeResult.FastestRoute.TotalTimeHours.ToString("F1") hours</p>
                        <p><strong>Stops:</strong> @(routeResult.FastestRoute.Path.Count - 1)</p>
                    </div>
                </div>
            </div>
        }
    </div>
}

@code {
    private RouteRequest request = new()
    {
        WeightTons = 10,
        CargoType = "General",
        WagonType = "Standard"
    };

    private bool isLoading = false;
    private string? errorMessage;
    private RouteResponse? routeResult;
    private List<string> availableCities = [];

    private readonly string[] cargoTypes = ["General", "Food", "Chemicals", "Electronics", "Machinery", "Pharmaceuticals"];
    private readonly string[] wagonTypes = ["Standard", "Refrigerated", "Tank", "Flatbed", "Container"];

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var resp = await Http.GetFromJsonAsync<CitiesResponse>("api/route/cities");
            if (resp?.Cities != null)
                availableCities = resp.Cities;
        }
        catch
        {
            // Cities list is optional – ignore errors
        }
    }

    private async Task OptimizeRoute()
    {
        if (string.IsNullOrWhiteSpace(request.From) || string.IsNullOrWhiteSpace(request.To))
        {
            errorMessage = "Please enter both From and To cities.";
            return;
        }
        if (request.WeightTons <= 0)
        {
            errorMessage = "Weight must be greater than 0.";
            return;
        }

        isLoading = true;
        errorMessage = null;
        routeResult = null;

        try
        {
            var response = await Http.PostAsJsonAsync("api/route/optimize", request);
            if (response.IsSuccessStatusCode)
            {
                routeResult = await response.Content.ReadFromJsonAsync<RouteResponse>();
            }
            else
            {
                var error = await response.Content.ReadFromJsonAsync<ErrorResponse>();
                errorMessage = error?.Error ?? "Route optimization failed.";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Cannot connect to API: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private class RouteRequest
    {
        public string From { get; set; } = string.Empty;
        public string To { get; set; } = string.Empty;
        public string CargoType { get; set; } = string.Empty;
        public double WeightTons { get; set; }
        public string WagonType { get; set; } = string.Empty;
    }

    private class RouteInfo
    {
        public List<string> Path { get; set; } = [];
        public double TotalCost { get; set; }
        public double TotalTimeHours { get; set; }
        public string OptimizationType { get; set; } = string.Empty;
    }

    private class RouteResponse
    {
        public RouteInfo? CheapestRoute { get; set; }
        public RouteInfo? FastestRoute { get; set; }
    }

    private class CitiesResponse
    {
        public List<string> Cities { get; set; } = [];
    }

    private class ErrorResponse
    {
        public string? Error { get; set; }
    }
}
