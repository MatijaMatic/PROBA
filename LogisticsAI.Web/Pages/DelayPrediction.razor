@page "/delay-prediction"
@inject HttpClient Http

<PageTitle>Delay Prediction</PageTitle>

<h2>⚡ Module 2 – Delay Prediction</h2>
<p class="text-muted">
    Enter transport details to predict the probability of delay using the ML model.
</p>

<div class="card mb-4">
    <div class="card-body">
        <div class="row g-3">
            <div class="col-md-6">
                <label class="form-label">Route From</label>
                <input class="form-control" @bind="request.RouteFrom" placeholder="e.g. Beograd" />
            </div>
            <div class="col-md-6">
                <label class="form-label">Route To</label>
                <input class="form-control" @bind="request.RouteTo" placeholder="e.g. Novi Sad" />
            </div>
            <div class="col-md-6">
                <label class="form-label">Carrier</label>
                <select class="form-select" @bind="request.Carrier">
                    <option value="">Select carrier...</option>
                    @foreach (var c in carriers)
                    {
                        <option value="@c">@c</option>
                    }
                </select>
            </div>
            <div class="col-md-6">
                <label class="form-label">Departure Hour (0–23)</label>
                <input type="number" class="form-control" @bind="request.DepartureHour"
                       min="0" max="23" placeholder="e.g. 14" />
            </div>
            <div class="col-md-4">
                <label class="form-label">Season</label>
                <select class="form-select" @bind="request.Season">
                    @foreach (var s in seasons)
                    {
                        <option value="@s">@s</option>
                    }
                </select>
            </div>
            <div class="col-md-4">
                <label class="form-label">Weather Condition</label>
                <select class="form-select" @bind="request.WeatherCondition">
                    @foreach (var w in weatherOptions)
                    {
                        <option value="@w">@w</option>
                    }
                </select>
            </div>
            <div class="col-md-4">
                <label class="form-label">Cargo Type</label>
                <select class="form-select" @bind="request.CargoType">
                    @foreach (var ct in cargoTypes)
                    {
                        <option value="@ct">@ct</option>
                    }
                </select>
            </div>
        </div>

        <div class="mt-3">
            <button class="btn btn-warning" @onclick="PredictDelay" disabled="@isLoading">
                @if (isLoading)
                {
                    <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                    <span>Predicting...</span>
                }
                else
                {
                    <span>⚡ Predict Delay</span>
                }
            </button>
        </div>
    </div>
</div>

@if (errorMessage != null)
{
    <div class="alert alert-danger"><strong>Error:</strong> @errorMessage</div>
}

@if (predictionResult != null)
{
    var pct = (predictionResult.DelayProbability * 100).ToString("F1");
    var alertClass = predictionResult.DelayPredicted ? "alert-danger" : "alert-success";
    var icon = predictionResult.DelayPredicted ? "⚠️" : "✅";

    <div class="card">
        <div class="card-header bg-light"><strong>Prediction Result</strong></div>
        <div class="card-body">
            <div class="alert @alertClass">
                <h4>@icon Delay @(predictionResult.DelayPredicted ? "Predicted" : "Unlikely")</h4>
                <p class="mb-0">
                    Probability of delay: <strong>@pct%</strong>
                    &nbsp; | &nbsp; Confidence: <strong>@predictionResult.Confidence</strong>
                </p>
            </div>

            <div class="mt-3">
                <div class="progress" style="height: 30px;">
                    <div class="progress-bar @(predictionResult.DelayPredicted ? "bg-danger" : "bg-success")"
                         role="progressbar"
                         style="width: @pct%"
                         aria-valuenow="@pct" aria-valuemin="0" aria-valuemax="100">
                        @pct%
                    </div>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private PredictRequest request = new()
    {
        Carrier = "DHL",
        Season = "Summer",
        WeatherCondition = "Clear",
        CargoType = "General",
        DepartureHour = "14"
    };

    private bool isLoading = false;
    private string? errorMessage;
    private PredictResponse? predictionResult;

    private readonly string[] carriers = ["DHL", "FedEx", "DB Cargo", "Schenker", "Kuehne+Nagel"];
    private readonly string[] seasons = ["Spring", "Summer", "Autumn", "Winter"];
    private readonly string[] weatherOptions = ["Clear", "Rain", "Snow", "Fog", "Storm"];
    private readonly string[] cargoTypes = ["General", "Food", "Chemicals", "Electronics", "Machinery", "Pharmaceuticals"];

    private async Task PredictDelay()
    {
        if (string.IsNullOrWhiteSpace(request.RouteFrom) || string.IsNullOrWhiteSpace(request.RouteTo))
        {
            errorMessage = "Please enter Route From and Route To.";
            return;
        }

        isLoading = true;
        errorMessage = null;
        predictionResult = null;

        try
        {
            var response = await Http.PostAsJsonAsync("api/delay/predict", request);
            if (response.IsSuccessStatusCode)
            {
                predictionResult = await response.Content.ReadFromJsonAsync<PredictResponse>();
            }
            else
            {
                var error = await response.Content.ReadFromJsonAsync<ErrorResponse>();
                errorMessage = error?.Error ?? "Prediction failed.";
                if (error?.Detail != null) errorMessage += $" ({error.Detail})";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Cannot connect to API: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private class PredictRequest
    {
        public string RouteFrom { get; set; } = string.Empty;
        public string RouteTo { get; set; } = string.Empty;
        public string Carrier { get; set; } = string.Empty;
        public string DepartureHour { get; set; } = string.Empty;
        public string Season { get; set; } = string.Empty;
        public string WeatherCondition { get; set; } = string.Empty;
        public string CargoType { get; set; } = string.Empty;
    }

    private class PredictResponse
    {
        public double DelayProbability { get; set; }
        public bool DelayPredicted { get; set; }
        public string Confidence { get; set; } = string.Empty;
    }

    private class ErrorResponse
    {
        public string? Error { get; set; }
        public string? Detail { get; set; }
    }
}
