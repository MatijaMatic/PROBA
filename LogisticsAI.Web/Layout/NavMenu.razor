        <div class="nav-item px-3">
            <NavLink class="nav-link" href="delay-prediction">
                <span class="bi bi-lightning-fill-nav-menu" aria-hidden="true"></span> Delay Prediction
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="route-optimizer">
                <span class="bi bi-signpost-split-fill-nav-menu" aria-hidden="true"></span> Route Optimizer
            </NavLink>
        </div>
    </nav>
</div>

@code {
    private bool collapseNavMenu = true;

    private string? NavMenuCssClass => collapseNavMenu ? "collapse" : null;

